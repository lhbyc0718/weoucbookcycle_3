.container {
  min-height: 100vh;
  background-color: #0f172a;
  color: #f1f5f9;
}

.header {
  padding: 48rpx 32rpx 32rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

/* User Section */
.user-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
}

.user-avatar {
  width: 192rpx;
  height: 192rpx;
  border-radius: 50%;
  margin-bottom: 24rpx;
  cursor: pointer;
  border: 2rpx solid transparent;
}

.user-avatar:hover {
  border-color: #a855f7;
}

.user-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.user-rank {
  padding: 8rpx 24rpx;
  background: linear-gradient(135deg, #6366f1, #a855f7);
  border-radius: 999rpx;
  margin-bottom: 32rpx;
}

.user-rank text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

.user-stats {
  display: flex;
  gap: 64rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.stat-label {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 8rpx;
}

/* Menu Section */
.menu-section {
  padding: 16rpx 32rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background-color: rgba(30, 41, 59, 0.4);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 24rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #e2e8f0;
}

.menu-arrow {
  font-size: 40rpx;
  color: #64748b;
}
