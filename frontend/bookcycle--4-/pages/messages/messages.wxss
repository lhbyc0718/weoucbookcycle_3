.container {
  min-height: 100vh;
  background-color: #0f172a;
  color: #f1f5f9;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 48rpx 32rpx 32rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
}

.bell-btn {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #1e293b;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.bell-btn text {
  font-size: 40rpx;
}

.red-dot {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 16rpx;
  height: 16rpx;
  background-color: #ef4444;
  border-radius: 50%;
  border: 4rpx solid #1e293b;
}

/* Search */
.search-box {
  position: relative;
  padding: 0 32rpx;
  margin-bottom: 48rpx;
}

.search-icon {
  position: absolute;
  left: 56rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
}

.search-input {
  width: 100%;
  padding: 24rpx 32rpx 24rpx 80rpx;
  background-color: rgba(30, 41, 59, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #e2e8f0;
  box-sizing: border-box;
}

.search-input::placeholder {
  color: #64748b;
}

/* Section */
.active-section {
  padding: 0 32rpx;
  margin-bottom: 48rpx;
}

.section-label {
  font-size: 22rpx;
  color: #64748b;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 24rpx;
}

.active-scroll {
  width: 100%;
  white-space: nowrap;
}

.active-list {
  display: flex;
  gap: 32rpx;
}

.active-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  min-width: 128rpx;
}

.avatar-wrapper {
  position: relative;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  padding: 4rpx;
  background: linear-gradient(135deg, #6366f1, #a855f7);
}

.online-dot {
  position: absolute;
  bottom: 8rpx;
  right: 8rpx;
  width: 24rpx;
  height: 24rpx;
  background-color: #10b981;
  border-radius: 50%;
  border: 4rpx solid #0f172a;
}

.user-name {
  font-size: 24rpx;
  color: #cbd5e1;
  text-align: center;
}

/* Chats */
.chats-section {
  padding: 0 32rpx;
}

.chat-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.chat-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 24rpx;
  background-color: rgba(30, 41, 59, 0.4);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
}

.chat-avatar {
  position: relative;
}

.avatar-img {
  width: 112rpx;
  height: 112rpx;
  border-radius: 24rpx;
}

.unread-badge {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: #6366f1;
  border-radius: 50%;
  border: 4rpx solid #0f172a;
  display: flex;
  align-items: center;
  justify-content: center;
}

.unread-badge text {
  font-size: 20rpx;
  font-weight: bold;
  color: #fff;
}

.chat-info {
  flex: 1;
  min-width: 0;
}

.chat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.chat-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #e2e8f0;
}

.chat-time {
  font-size: 24rpx;
  color: #64748b;
}

.chat-message {
  font-size: 26rpx;
  color: #64748b;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chat-message.unread {
  color: #cbd5e1;
  font-weight: 500;
}
