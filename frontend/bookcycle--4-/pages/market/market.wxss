.container {
  min-height: 100vh;
  background-color: #0f172a;
  color: #f1f5f9;
}

.header {
  position: sticky;
  top: 0;
  z-index: 30;
  padding: 24rpx 32rpx;
  background-color: rgba(15, 23, 42, 0.95);
  backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.search-box {
  position: relative;
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.search-icon {
  position: absolute;
  left: 28rpx;
  font-size: 32rpx;
}

.search-input {
  width: 100%;
  padding: 24rpx 24rpx 24rpx 80rpx;
  font-size: 28rpx;
  color: #e2e8f0;
  background-color: rgba(30, 41, 59, 0.5);
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.search-input::placeholder {
  color: #64748b;
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
}

.filter-tags {
  display: flex;
  gap: 16rpx;
}

.filter-btn {
  display: inline-flex;
  padding: 12rpx 24rpx;
  background-color: #1e293b;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  font-size: 24rpx;
  color: #94a3b8;
  white-space: nowrap;
}

.filter-btn.active,
.filter-btn.selected {
  background-color: rgba(99, 102, 241, 0.2);
  border-color: #6366f1;
  color: #c7d2fe;
}

/* Filter Panel */
.filter-panel {
  margin-top: 32rpx;
  padding: 32rpx;
  background-color: #0f172a;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 24rpx;
}

.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.filter-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.clear-all {
  font-size: 24rpx;
  color: #818cf8;
}

.filter-section {
  margin-bottom: 32rpx;
}

.filter-label {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 16rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-option {
  padding: 12rpx 24rpx;
  background-color: #1e293b;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  font-size: 24rpx;
  color: #94a3b8;
}

.filter-option.selected {
  background-color: rgba(99, 102, 241, 0.2);
  border-color: #6366f1;
  color: #c7d2fe;
}

/* Content */
.content {
  padding: 32rpx;
}

.result-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.result-count {
  font-size: 28rpx;
  color: #64748b;
}

.sort-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #818cf8;
}

.book-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 32rpx;
}

.book-card {
  width: 48%;
  background-color: #1e293b;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.book-cover {
  width: 100%;
  height: 280rpx;
}

.book-info {
  padding: 20rpx;
}

.book-title {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #f1f5f9;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.book-author {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 8rpx;
}

.book-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.book-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #818cf8;
}

.book-condition {
  font-size: 20rpx;
  color: #64748b;
}

/* tags displayed under title/author in book cards */
.book-tags {
  margin-top: 8rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
.book-tags .tag {
  padding: 4rpx 12rpx;
  font-size: 18rpx;
  color: #c7d2fe;
  background-color: rgba(99, 102, 241, 0.2);
  border-radius: 12rpx;
}


.wishlist-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.no-result {
  text-align: center;
  padding: 96rpx 0;
  color: #64748b;
}

.clear-link {
  display: block;
  margin-top: 16rpx;
  color: #818cf8;
  font-size: 28rpx;
}
