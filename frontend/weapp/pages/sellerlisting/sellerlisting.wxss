/* pages/sellerlisting/sellerlisting.wxss */
.container {
  min-height: 100vh;
  background-color: #0f172a;
  color: #f1f5f9;
}

/* Header */
.header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background-color: rgba(15, 23, 42, 0.95);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
  position: sticky;
  top: 0;
  z-index: 10;
}

.back-btn {
  width: 56rpx;
  height: 56rpx;
  background: transparent;
  border: none;
  color: #94a3b8;
  font-size: 32rpx;
  line-height: 1;
  padding: 0;
}

.header-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

/* Seller Card */
.seller-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(236, 72, 153, 0.05));
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.seller-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  object-fit: cover;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.seller-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.seller-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.seller-stats {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.stat {
  font-size: 20rpx;
  color: #cbd5e1;
}

.stat.verified {
  color: #22c55e;
  font-weight: bold;
}

/* Search Box */
.search-box {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background-color: rgba(30, 41, 59, 0.3);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.search-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.search-input {
  flex: 1;
  padding: 12rpx 16rpx;
  background-color: rgba(30, 41, 59, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #e2e8f0;
}

.search-input::placeholder {
  color: #64748b;
}

/* Content */
.content {
  padding: 24rpx;
}

.empty {
  text-align: center;
  padding: 60rpx 24rpx;
  color: #94a3b8;
  font-size: 26rpx;
}

/* Book Grid */
.book-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.book-card {
  width: 48%;
  background-color: #1e293b;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.book-cover {
  width: 100%;
  height: 220rpx;
}

.book-info {
  padding: 16rpx;
}

.book-title {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
  color: #f1f5f9;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.book-author {
  display: block;
  font-size: 18rpx;
  color: #94a3b8;
  margin-top: 6rpx;
}

.book-tags {
  margin-top: 8rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.book-tags .tag {
  padding: 4rpx 10rpx;
  font-size: 16rpx;
  color: #c7d2fe;
  background-color: rgba(99, 102, 241, 0.2);
  border-radius: 10rpx;
}

.book-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.book-price {
  font-size: 28rpx;
  font-weight: bold;
  color: #818cf8;
}

.book-condition {
  font-size: 18rpx;
  color: #64748b;
}

.wishlist-btn {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 48rpx;
  height: 48rpx;
  background-color: rgba(0, 0, 0, 0.4);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}
