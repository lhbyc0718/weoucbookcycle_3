<view class="container">
  <!-- Header -->
  <view class="header">
    <button class="back-btn" bindtap="onBack">‹</button>
    <text class="header-title">{{seller.name || 'Seller Listings'}}</text>
  </view>

  <!-- Seller Info Card -->
  <view class="seller-card">
    <image class="seller-avatar" src="{{seller.avatar}}" mode="aspectFill"></image>
    <view class="seller-details">
      <text class="seller-name">{{seller.name}}</text>
      <view class="seller-stats">
        <text class="stat">{{seller.sales}} Sales</text>
        <text class="stat">{{seller.trustScore}} Trust</text>
        <text class="stat verified" wx:if="{{seller.verified}}">✓ Verified</text>
      </view>
    </view>
  </view>

  <!-- Search Box -->
  <view class="search-box">
    <text class="search-icon">🔍</text>
    <input 
      class="search-input" 
      placeholder="Search books..." 
      value="{{searchQuery}}"
      bindinput="onSearchInput"
    />
  </view>

  <!-- Books Grid -->
  <view class="content">
    <block wx:if="{{sellerBooks.length > 0}}">
      <view class="book-grid">
        <block wx:for="{{sellerBooks}}" wx:key="id">
          <view class="book-card" bindtap="onBookClick" data-id="{{item.id}}">
            <image class="book-cover" src="{{item.cover}}" mode="aspectFill"></image>
            <view class="book-info">
              <text class="book-title">{{item.title}}</text>
              <text class="book-author">{{item.author}}</text>
              <view class="book-tags" wx:if="{{item.tags && item.tags.length}}">
                <block wx:for="{{item.tags}}" wx:key="*this">
                  <text class="tag">{{item}}</text>
                </block>
              </view>
              <view class="book-footer">
                <text class="book-price">¥{{item.price}}</text>
                <text class="book-condition">{{item.condition}}</text>
              </view>
            </view>
            <view class="wishlist-btn" catchtap="onToggleWishlist" data-id="{{item.id}}">
              <text>🤍</text>
            </view>
          </view>
        </block>
      </view>
    </block>

    <view class="empty" wx:if="{{sellerBooks.length === 0}}">
      <text>This seller has no listings.</text>
    </view>
  </view>
</view>
