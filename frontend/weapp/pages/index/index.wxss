.container {
  min-height: 100vh;
  background-color: #0f172a;
  color: #f1f5f9;
  padding-bottom: 120rpx;
}

/* Header */
.header {
  position: sticky;
  top: 0;
  z-index: 30;
  padding: 24rpx 32rpx;
  background-color: rgba(15, 23, 42, 0.95);
  backdrop-filter: blur(20rpx);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #818cf8;
}

.bell-btn {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #1e293b;
  border-radius: 50%;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.bell-icon {
  font-size: 40rpx;
}

.red-dot {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 16rpx;
  height: 16rpx;
  background-color: #ef4444;
  border-radius: 50%;
  border: 4rpx solid #1e293b;
}

/* Search Box */
.search-box {
  position: relative;
  display: flex;
  align-items: center;
  background-color: rgba(30, 41, 59, 0.5);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.search-icon {
  padding-left: 28rpx;
  font-size: 32rpx;
}

.search-input {
  flex: 1;
  padding: 28rpx 24rpx;
  font-size: 28rpx;
  color: #e2e8f0;
  background: transparent;
}

.search-input::placeholder {
  color: #64748b;
}

.scan-btn {
  padding: 16rpx 24rpx;
}

/* Carousel */
.carousel {
  width: 100%;
  height: 384rpx;
  white-space: nowrap;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.carousel-item {
  display: inline-block;
  width: 90%;
  height: 384rpx;
  margin-right: 32rpx;
  border-radius: 48rpx;
  overflow: hidden;
  position: relative;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.carousel-img {
  width: 100%;
  height: 100%;
  position: absolute;
}

.carousel-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 48rpx;
  background: linear-gradient(to top, rgba(15, 23, 42, 0.9), transparent);
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background-color: rgba(99, 102, 241, 0.3);
  border: 1rpx solid rgba(99, 102, 241, 0.3);
  border-radius: 999rpx;
  margin-bottom: 16rpx;
}

.tag-amber {
  background-color: rgba(245, 158, 11, 0.3);
  border-color: rgba(245, 158, 11, 0.3);
}

.tag-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: #818cf8;
  border-radius: 50%;
  margin-right: 12rpx;
  animation: pulse 2s infinite;
}

.tag-dot-amber {
  background-color: #fbbf24;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.tag text {
  font-size: 22rpx;
  color: #c7d2fe;
  font-weight: bold;
}

.carousel-title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.carousel-desc {
  display: block;
  font-size: 26rpx;
  color: #cbd5e1;
}

/* Categories */
.categories {
  padding: 32rpx;
}

.categories-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #f1f5f9;
  display: flex;
  align-items: center;
}

.clear-filter {
  font-size: 24rpx;
  color: #818cf8;
}

.categories-scroll {
  width: 100%;
  white-space: nowrap;
}

.category-list {
  display: flex;
  gap: 24rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.category-item.selected .category-icon {
  border-color: #818cf8;
  box-shadow: 0 0 0 8rpx rgba(129, 140, 248, 0.3);
}

.category-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1e293b, #334155);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  font-size: 48rpx;
}

.category-icon.orange { background: linear-gradient(135deg, #f97316, #ec4899); }
.category-icon.blue { background: linear-gradient(135deg, #3b82f6, #6366f1); }
.category-icon.green { background: linear-gradient(135deg, #10b981, #14b8a6); }
.category-icon.purple { background: linear-gradient(135deg, #a855f7, #d946ef); }
.category-icon.slate { background: linear-gradient(135deg, #475569, #64748b); }

.category-label {
  font-size: 20rpx;
  color: #94a3b8;
}

.category-item.selected .category-label {
  color: #818cf8;
}

/* Book Section */
.book-section {
  padding: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.live-dot {
  width: 20rpx;
  height: 20rpx;
  background-color: #818cf8;
  border-radius: 50%;
  margin-left: 16rpx;
  animation: pulse 2s infinite;
}

.view-toggle {
  display: flex;
  gap: 8rpx;
  background-color: #1e293b;
  padding: 8rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.toggle-btn {
  padding: 12rpx 16rpx;
  border-radius: 8rpx;
  color: #64748b;
}

.toggle-btn.active {
  background-color: rgba(255, 255, 255, 0.1);
  color: #fff;
}

/* Book Grid */
.book-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 32rpx;
}

.book-card {
  width: 48%;
  background-color: #1e293b;
  border-radius: 24rpx;
  overflow: hidden;
  position: relative;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.book-cover {
  width: 100%;
  height: 280rpx;
}

.book-info {
  padding: 20rpx;
}

.book-title {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #f1f5f9;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.book-author {
  display: block;
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 8rpx;
}

.book-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.book-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #818cf8;
}

.book-condition {
  font-size: 20rpx;
  color: #64748b;
}

/* tags shown on each book card */
.book-tags {
  margin-top: 8rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
.book-tags .tag {
  padding: 4rpx 12rpx;
  font-size: 18rpx;
  color: #c7d2fe;
  background-color: rgba(99, 102, 241, 0.2);
  border-radius: 12rpx;
}


.wishlist-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.no-result {
  text-align: center;
  padding: 96rpx 0;
  color: #64748b;
}

.clear-link {
  display: block;
  margin-top: 16rpx;
  color: #818cf8;
  font-size: 28rpx;
}

.load-more {
  text-align: center;
  margin-top: 64rpx;
  margin-bottom: 48rpx;
}

.load-more-btn {
  padding: 24rpx 64rpx;
  background-color: #1e293b;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 999rpx;
  color: #cbd5e1;
  font-size: 28rpx;
}
