.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
  background-color: #f8f8f8;
}

.header {
  margin-bottom: 80rpx;
  text-align: center;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.logo-text {
  background: linear-gradient(90deg, #2563EB, #7C3AED);
  -webkit-background-clip: text;
  color: transparent;
  font-family: 'Times New Roman', serif;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #888;
}

.content {
  width: 100%;
}

.form-group {
  width: 100%;
  margin-bottom: 40rpx;
}

.input-group {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.label {
  width: 100rpx;
  font-size: 28rpx;
  color: #666;
}

.input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.submit-btn {
  width: 100%;
  margin-top: 40rpx;
  margin-bottom: 24rpx;
}

.links {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  font-size: 26rpx;
  color: #666;
  margin-top: 20rpx;
}

.login-btn {
  width: 100%;
  margin-bottom: 24rpx;
}

.outline-btn {
  width: 100%;
  background-color: transparent;
  border: 2rpx solid #ddd;
  color: #666;
  margin-bottom: 24rpx;
}

.cancel-btn {
  width: 100%;
  background-color: transparent !important;
  color: #999 !important;
  margin-top: 40rpx;
}
