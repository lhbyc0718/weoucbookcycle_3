/* pages/wishlist/wishlist.wxss */
.container { min-height:100vh; background:#0f172a; color:#f1f5f9; }
.header { padding: 28rpx; border-bottom:1rpx solid rgba(255,255,255,0.04); }
.header-title { font-size:36rpx; font-weight:bold; color:#fff; }
.content { padding: 24rpx; }
.empty { text-align:center; color:#94a3b8; margin-top:40rpx; }
.book-grid { display:flex; flex-wrap:wrap; gap:20rpx; }
.book-card { width:48%; background:#1e293b; border-radius:20rpx; overflow:hidden; position:relative; }
.book-cover { width:100%; height:220rpx; }
.book-info { padding:16rpx; }
.book-title { display:block; font-size:24rpx; color:#fff; }
.book-author { display:block; font-size:18rpx; color:#94a3b8; margin-top:8rpx; }
.book-footer { display:flex; justify-content:space-between; align-items:center; margin-top:12rpx; }
.wishlist-btn { position:absolute; top:12rpx; right:12rpx; width:48rpx; height:48rpx; border-radius:50%; background:rgba(0,0,0,0.4); display:flex; align-items:center; justify-content:center; }
