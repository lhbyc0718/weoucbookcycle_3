<view class="container">
  <view class="header">
    <button class="back-btn" bindtap="onBack">‹</button>
    <text class="header-title">My Listings</text>
  </view>

  <view class="search-box">
    <text class="search-icon">🔍</text>
    <input class="search-input" placeholder="Search my books..." value="{{searchQuery}}" bindinput="onSearchInput" />
  </view>

  <view class="content">
    <view wx:if="{{books.length === 0}}" class="empty">
      <text>You haven't listed any books yet.</text>
    </view>
    <view class="book-grid">
      <block wx:for="{{books}}" wx:key="id">
        <view class="book-card" bindtap="onBookClick" data-id="{{item.id}}">
          <image class="book-cover" src="{{item.cover}}" mode="aspectFill"></image>
          <view class="book-info">
            <text class="book-title">{{item.title}}</text>
            <text class="book-author">{{item.author}}</text>
            <view class="book-footer">
              <text class="book-price">¥{{item.price}}</text>
              <text class="book-condition">{{item.condition}}</text>
            </view>
          </view>
          <view class="wishlist-btn" catchtap="onToggleWishlist" data-id="{{item.id}}"><text>🤍</text></view>
          <view class="delete-btn" catchtap="onDeleteListing" data-id="{{item.id}}"><text>🗑️</text></view>
        </view>
      </block>
    </view>
  </view>
</view>