<view class="container">
  <!-- Messages -->
  <scroll-view class="messages-list" scroll-y="true" scroll-into-view="{{scrollIntoView}}">
    <block wx:if="{{messages && messages.length > 0}}" wx:for="{{messages}}" wx:key="id">
      <view class="message-item {{item.senderId === 'me' ? 'sent' : 'received'}}" id="msg-{{item.id}}">
        <image class="message-avatar" src="{{item.senderId === 'me' ? myAvatar : (otherUser.avatar || 'https://images.unsplash.com/photo-1599566150163-29194dcaad36?w=150&h=150&fit=crop')}}" mode="aspectFill"></image>
        <view class="message-bubble">
          <text class="message-text">{{item.text || ''}}</text>
        </view>
      </view>
    </block>
    
    <!-- Empty state -->
    <view class="empty-messages" wx:if="{{!messages || messages.length === 0}}">
      <text>No messages yet. Start a conversation!</text>
    </view>
  </scroll-view>

  <!-- Input Bar -->
  <view class="input-bar">
    <input 
      class="message-input" 
      placeholder="Type a message..." 
      value="{{inputText}}"
      bindinput="onInput"
      bindconfirm="onSend"
    />
    <view class="send-btn" bindtap="onSend">
      <text>➤</text>
    </view>
  </view>
</view>
