<view class="container">
  <!-- Header -->
  <view class="header">
    <text class="header-title">My Profile</text>
  </view>

  <!-- User Info -->
  <view class="user-section">
    <image class="user-avatar" src="{{user.avatar || 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=150&h=150&fit=crop'}}" mode="aspectFill"></image>
    
    <block wx:if="{{isLoggedIn}}">
        <view class="user-name-row" style="display: flex; align-items: center; justify-content: center; gap: 10rpx;">
            <text class="user-name">{{user.username}}</text>
            <view wx:if="{{user.isAdmin}}" style="background: #7e22ce; color: white; font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 20rpx;">管理员</view>
        </view>
        <view class="user-rank">
            <text>Trust Score: {{user.trust_score}}</text>
        </view>
    </block>
    <block wx:else>
        <button class="login-btn" bindtap="onLoginTap" type="primary" size="mini">微信登录</button>
    </block>
  </view>

  <!-- Menu -->
  <view class="menu-section">
    <view class="menu-item" bindtap="onMyListings">
      <text class="menu-icon">📚</text>
      <text class="menu-text">My Listings</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="onWishlist">
      <text class="menu-icon">❤️</text>
      <text class="menu-text">Wishlist</text>
      <text class="menu-arrow">›</text>
    </view>
    
    <block wx:if="{{isLoggedIn}}">
        <view class="menu-item" bindtap="onLogoutTap" style="margin-top: 20rpx; border-top: 1px solid #eee;">
            <text class="menu-icon">🚪</text>
            <text class="menu-text" style="color: red;">退出登录</text>
            <text class="menu-arrow"></text>
        </view>
    </block>
  </view>

  <!-- Privacy Policy Link (Required for compliance) -->
  <view style="margin-top: 50rpx; text-align: center;">
      <navigator url="/pages/privacy/privacy" style="color: #666; font-size: 24rpx; text-decoration: underline;">用户协议与隐私政策</navigator>
  </view>
</view>
