.container {
  min-height: 100vh;
  background-color: #0f172a;
  color: #f1f5f9;
  padding-bottom: 120rpx;
}

/* Swiper */
.book-swiper {
  width: 100%;
  height: 600rpx;
}

.book-image {
  width: 100%;
  height: 100%;
}

/* Content */
.content {
  padding: 32rpx;
}

.price-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.book-price {
  font-size: 56rpx;
  font-weight: bold;
  color: #818cf8;
}

.book-condition {
  padding: 8rpx 16rpx;
  background-color: rgba(30, 41, 59, 0.5);
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.book-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.book-author {
  display: block;
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 24rpx;
}

/* Info Tags */
.info-tags {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.info-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background-color: rgba(30, 41, 59, 0.5);
  border-radius: 12rpx;
}

.tag-icon {
  font-size: 24rpx;
}

.tag-text {
  font-size: 24rpx;
  color: #94a3b8;
}

/* Section */
.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.description-section {
  margin-bottom: 32rpx;
}

.description {
  font-size: 28rpx;
  color: #94a3b8;
  line-height: 1.6;
}

/* Tags */
.tags-section {
  margin-bottom: 32rpx;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  padding: 12rpx 24rpx;
  background-color: rgba(99, 102, 241, 0.2);
  border: 1rpx solid rgba(99, 102, 241, 0.3);
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #c7d2fe;
}

/* Seller */
.seller-section {
  margin-bottom: 32rpx;
}

.seller-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: rgba(30, 41, 59, 0.5);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.seller-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.seller-info {
  flex: 1;
}

.seller-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.seller-stats {
  display: flex;
  gap: 24rpx;
}

.seller-stat {
  font-size: 24rpx;
  color: #64748b;
}

.verified-badge {
  width: 48rpx;
  height: 48rpx;
  background-color: #10b981;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

/* Action Bar */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background-color: rgba(15, 23, 42, 0.95);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(255, 255, 255, 0.05);
}

.wishlist-btn {
  width: 100rpx;
  height: 100rpx;
  background-color: #1e293b;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.chat-btn {
  flex: 1;
  height: 100rpx;
  background: linear-gradient(135deg, #4f46e5, #7c3aed);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.delete-btn {
  width: 100rpx;
  height: 100rpx;
  background-color: #ef4444;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}
